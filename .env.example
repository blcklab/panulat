APP_NAME="Panulat API"
APP_DESCRIPTION="Clean REST APIs with Panulat."
APP_ENV=local
APP_DEBUG=true
PANULAT_LOCALE=en

# Database
# SQLite is the easiest local default.
DB_CONNECTION=sqlite
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=database/database.sqlite
DB_USERNAME=root
DB_PASSWORD=
DB_CHARSET=utf8mb4

# MySQL example:
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=panulat
# DB_USERNAME=panulat
# DB_PASSWORD=secret
# DB_CHARSET=utf8mb4

# Optional advanced override. Leave empty unless you want full PDO DSN control.
DB_DSN=
DB_QUERY_LOG=false

CACHE_DRIVER=file
CORS_ALLOWED_ORIGINS=*

# Rate limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_MAX_ATTEMPTS=60
RATE_LIMIT_DECAY_SECONDS=60
RATE_LIMIT_API_MAX_ATTEMPTS=60
RATE_LIMIT_API_DECAY_SECONDS=60
RATE_LIMIT_LOGIN_MAX_ATTEMPTS=5
RATE_LIMIT_LOGIN_DECAY_SECONDS=60

HTTP_MAX_BODY_BYTES=1048576

# Logging
LOG_REQUESTS=false
LOG_CHANNEL=stderr
LOG_PATH=storage/logs/app.log
LOG_MAX_BYTES=5242880
LOG_LOCK=false

# Auth
JWT_SECRET=change-this-to-a-long-random-secret-before-production
JWT_TTL=3600
API_KEYS=local-dev-key

# Local development keeps optimization requirements disabled.
# For production, run php bin/console optimize and set these to true.
PANULAT_REQUIRE_CACHED_CONFIG=false
PANULAT_REQUIRE_CACHED_ROUTES=false
PANULAT_REQUIRE_CACHED_CONTAINER=false
PANULAT_PRE_RESOLVE_GLOBAL_MIDDLEWARE=false
PANULAT_EMIT_CONTENT_LENGTH=true
